<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>

	<appSettings>
		<add key="P_threshold" value="5"/>
		<add key="VPact_threshold" value="2"/>
		<add key="VPdef_threshold" value="2"/>
		<add key="OutOfBandPercentage" value="25"/>
	</appSettings>

	<system.serviceModel>

		<bindings>
			<netTcpBinding>
				<binding name="WeatherBinding"
						 transferMode="Streamed"
						 maxReceivedMessageSize="10485760"
						 sendTimeout="00:10:00"
						 receiveTimeout="00:10:00"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00" />
			</netTcpBinding>
		</bindings>

		<client>
			<endpoint name="WeatherService"
					  address="net.tcp://localhost:4002/ServiceWeather"
					  binding="netTcpBinding"
					  bindingConfiguration="WeatherBinding"
					  contract="Common.IWeatherService"/>
		</client>

	</system.serviceModel>
</configuration>